PORT=4000

# Logging: debug | info | warn | error (default: debug in development, info in production)
#LOG_LEVEL=info

# LLM providers (build order step 3). At least one key is required for real
# generation; without either, POST /api/chat returns 501 with a clear
# explanation instead of crashing (cache hits still work with no keys).
#
# Selection: LLM_PROVIDER=anthropic|openai forces one; unset, Anthropic is
# preferred when both keys are present.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
#LLM_PROVIDER=anthropic

# Optional. Without this, caching, progress tracking, and PDF grounding
# are disabled - /api/chat still works, just without them. A configured
# but unreachable database degrades to a cache miss rather than crashing.
# Needs the pgvector extension (RAG chunk table); see docs/architecture.md.
# Matches apps/api/docker-compose.yml (host port 5433 → container 5432).
DATABASE_URL=postgres://gloomy:gloomy@localhost:5433/gloomy_dev

# Public URLs (production deploy only). PUBLIC_API_URL makes the agent
# manifest at /.well-known/agent.json advertise the real, permanent HTTPS
# endpoint that gets registered on-chain as gloomy's ASP service URL.
# PUBLIC_WEB_URL is the frontend homepage shown in the manifest.
#PUBLIC_API_URL=https://api.your-domain.com
#PUBLIC_WEB_URL=https://your-gloomy.vercel.app

# Optional shared secret for POST /api/agent/task (the marketplace
# fulfillment endpoint - it burns LLM tokens, and marketplace work is paid).
# When set, callers must send it as an `x-agent-key` header; unset = open.
#AGENT_TASK_KEY=

# OKX Developer Portal API key triad (web3.okx.com/onchain-os/dev-portal).
# NOT read by this app/server - these are for the global `onchainos` CLI's
# API-Key login (`onchainos wallet login`, no email), which reads them from
# the process env / `~/.onchainos/.env`, not from this file. Documented here
# only so teammates know the names; never put real values in this file.
#OKX_API_KEY=
#OKX_SECRET_KEY=
#OKX_PASSPHRASE=
