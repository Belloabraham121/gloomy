PORT=4000

# LLM providers (build order step 3). At least one key is required for real
# generation; without either, POST /api/chat returns 501 with a clear
# explanation instead of crashing (cache hits still work with no keys).
#
# Selection: LLM_PROVIDER=anthropic|openai forces one; unset, Anthropic is
# preferred when both keys are present.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
#LLM_PROVIDER=anthropic

# Optional (build order step 6). Without this, caching and progress
# tracking are silently disabled - /api/chat still works, just without
# them. Needs the pgvector extension available (for step 4's future RAG
# tables); see docs/architecture.md.
DATABASE_URL=postgres://gloomy:gloomy@localhost:5432/gloomy_dev
