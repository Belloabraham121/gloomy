PORT=4000

# Required for real Claude tool-use (build order step 3). Without this,
# POST /api/chat returns 501 with a clear explanation instead of crashing.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Optional (build order step 6). Without this, caching and progress
# tracking are silently disabled - /api/chat still works, just without
# them. Needs the pgvector extension available (for step 4's future RAG
# tables); see docs/architecture.md.
DATABASE_URL=postgres://gloomy:gloomy@localhost:5432/gloomy_dev
