# LLM provider for the CopilotKit runtime (/api/copilotkit). At least one
# key is required for the chat to respond; the 3D scene itself works
# without any keys via the manual control panel.
#
# LLM_PROVIDER=anthropic|openai forces one; unset, Anthropic is preferred
# when both keys are present (same convention as apps/api).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
#LLM_PROVIDER=anthropic
